{
  "ConnectionStrings": {
    "Default": "Data Source=act.db"
  },
  "JwtSettings": {
    "Secret": "ACT-SuperSecret-Key-Change-In-Production-Min32Chars!",
    "Issuer": "ACT.API",
    "Audience": "ACT.Client",
    "ExpiryMinutes": 480
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}